# ============================================================
# SECRETS — Never commit these
# ============================================================
# .env holds SonarQube tokens and any other local secrets.
# Copy .env.example → .env and fill in your real values locally.
.env
.env.*
!.env.example
# Angular environment file – holds the real Google Client ID.
# Copy src/environments/environment.example.ts → environment.ts and fill in values.
src/environments/environment.ts
!src/environments/environment.example.ts# ============================================================
